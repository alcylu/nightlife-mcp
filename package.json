{
  "name": "nightlife-mcp",
  "version": "0.3.0",
  "description": "MCP server for nightlife event discovery",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx src/index.ts",
    "dev:http": "tsx src/http.ts",
    "key:create": "tsx src/scripts/createApiKey.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "start:http": "node dist/http.js",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "tsx --test src/**/*.test.ts",
    "smoke:prod:auth": "node scripts/prod-auth-smoke.mjs"
  },
  "keywords": [
    "mcp",
    "nightlife",
    "events",
    "supabase"
  ],
  "author": "Nightlife Tokyo <hello@nightlifetokyo.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/alcylu/nightlife-mcp"
  },
  "homepage": "https://nightlife.dev",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "@scalar/express-api-reference": "^0.8.46",
    "@supabase/supabase-js": "^2.97.0",
    "date-fns-tz": "^3.2.0",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.3.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
